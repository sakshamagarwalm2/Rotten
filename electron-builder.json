{
  "appId": "com.rotten.docxtoppt",
  "productName": "Rotten",
  "directories": {
    "output": "dist"
  },
  "files": [
    "electron/**/*",
    "out/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
